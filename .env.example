# Neon pooled connection string for app runtime.
# Example: postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://replace_me"

# Neon direct connection string for Prisma schema operations.
# Example: postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL="postgresql://replace_me"

# 32-byte key encoded in base64 for token encryption.
# Generate one with:
# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY="replace_me"

# Required for admin-only API actions and admin page requests.
ADMIN_API_KEY="replace_with_long_random_string"

# Required for Google OAuth admin login (NextAuth).
# Generate one with:
# openssl rand -base64 32
AUTH_SECRET="replace_me"

# Google OAuth Web Client credentials.
AUTH_GOOGLE_ID="replace_me"
AUTH_GOOGLE_SECRET="replace_me"

# Comma-separated Google account emails allowed to use admin mode.
ADMIN_GOOGLE_ALLOWED_EMAILS="you@gmail.com"

# Optional for local development callback URLs.
NEXTAUTH_URL="http://localhost:3000"

# Leaderboard auto-refresh staleness window in milliseconds (default: 300000 = 5 minutes).
LEADERBOARD_REFRESH_INTERVAL_MS="300000"

# Minimum delay between sequential WaniKani refresh requests in milliseconds (default: 1000).
LEADERBOARD_REQUEST_GAP_MS="1000"
