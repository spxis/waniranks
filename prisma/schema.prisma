generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id             String   @id @default(cuid())
  nickname       String   @unique
  tokenEncrypted String
  tokenIv        String
  tokenTag       String
  wkUserId       String   @unique
  wkUsername     String
  wkLevel        Int
  reviewCount    Int      @default(0)
  burnedCount    Int      @default(0)
  pendingReviews Int      @default(0)
  radicalCount   Int      @default(0)
  vocabularyCount Int     @default(0)
  apprenticeCount Int     @default(0)
  guruCount       Int     @default(0)
  masterCount     Int     @default(0)
  enlightenedCount Int    @default(0)
  levelKanjiTotal Int     @default(0)
  levelKanjiLearned Int   @default(0)
  levelKanjiGuruPlus Int  @default(0)
  levelKanjiLocked Int    @default(0)
  estimatedHoursRemaining Int?
  levelKanjiItems Json?
  itemSpread      Json?
  jlptCounts      Json?
  lastActivityAt  DateTime?
  isSyncing       Boolean  @default(false)
  syncLockUntil   DateTime?
  nextSyncAllowedAt DateTime @default(now())
  lastSyncStatus  String   @default("idle")
  lastSyncError   String?
  score          Int      @default(0)
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LevelSnapshot {
  id                String   @id @default(cuid())
  accountId         String
  level             Int
  kanjiTotal        Int      @default(0)
  kanjiLearned      Int      @default(0)
  kanjiGuruPlus     Int      @default(0)
  kanjiLocked       Int      @default(0)
  estimatedHoursRemaining Int?
  items             Json?
  syncedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, level])
  @@index([accountId])
}

model DailyAccountSnapshot {
  id                 String   @id @default(cuid())
  accountId          String
  snapshotDatePst    String
  snapshotAt         DateTime @default(now())
  wkLevel            Int
  reviewCount        Int
  burnedCount        Int
  pendingReviews     Int
  radicalCount       Int
  vocabularyCount    Int
  apprenticeCount    Int
  guruCount          Int
  masterCount        Int
  enlightenedCount   Int
  levelKanjiLearned  Int
  levelKanjiTotal    Int
  score              Int
  lastActivityAt     DateTime?
  lastSyncedAt       DateTime

  @@unique([accountId, snapshotDatePst])
  @@index([accountId])
}

model JlptKanji {
  id        String   @id @default(cuid())
  kanji     String   @unique
  nLevel    Int
  strokeCount Int?
  primaryMeaning String?
  meanings   String[] @default([])
  onReadings String[] @default([])
  kunReadings String[] @default([])
  nanoriReadings String[] @default([])
  enrichedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nLevel])
}
