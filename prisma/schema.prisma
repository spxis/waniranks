generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id             String   @id @default(cuid())
  nickname       String
  joinedByEmail  String?
  joinedByName   String?
  inviteCodeHash String?
  inviteCodeUpdatedAt DateTime?
  tokenEncrypted String
  tokenIv        String
  tokenTag       String
  wkUserId       String   @unique
  wkUsername     String
  wkLevel        Int
  reviewCount    Int      @default(0)
  burnedCount    Int      @default(0)
  pendingReviews Int      @default(0)
  radicalCount   Int      @default(0)
  vocabularyCount Int     @default(0)
  apprenticeCount Int     @default(0)
  guruCount       Int     @default(0)
  masterCount     Int     @default(0)
  enlightenedCount Int    @default(0)
  levelKanjiTotal Int     @default(0)
  levelKanjiLearned Int   @default(0)
  levelKanjiGuruPlus Int  @default(0)
  levelKanjiLocked Int    @default(0)
  estimatedHoursRemaining Int?
  levelKanjiItems Json?
  itemSpread      Json?
  jlptCounts      Json?
  assignmentCache Json?
  assignmentCacheUpdatedAt DateTime?
  reviewsUpdatedAt DateTime?
  lastRadicalGuruedAt DateTime?
  lastKanjiGuruedAt DateTime?
  lastVocabularyGuruedAt DateTime?
  lastRadicalGuruedItem Json?
  lastKanjiGuruedItem Json?
  lastVocabularyGuruedItem Json?
  wkHttpCache     Json?
  lastActivityAt  DateTime?
  isSyncing       Boolean  @default(false)
  syncLockUntil   DateTime?
  nextSyncAllowedAt DateTime @default(now())
  lastSyncStatus  String   @default("idle")
  lastSyncError   String?
  score          Int      @default(0)
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LevelSnapshot {
  id                String   @id @default(cuid())
  accountId         String
  level             Int
  kanjiTotal        Int      @default(0)
  kanjiLearned      Int      @default(0)
  kanjiGuruPlus     Int      @default(0)
  kanjiLocked       Int      @default(0)
  estimatedHoursRemaining Int?
  items             Json?
  syncedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, level])
  @@index([accountId])
}

model DailyAccountSnapshot {
  id                 String   @id @default(cuid())
  accountId          String
  snapshotDatePst    String
  snapshotAt         DateTime @default(now())
  wkLevel            Int
  reviewCount        Int
  burnedCount        Int
  pendingReviews     Int
  radicalCount       Int
  vocabularyCount    Int
  apprenticeCount    Int
  guruCount          Int
  masterCount        Int
  enlightenedCount   Int
  levelKanjiLearned  Int
  levelKanjiTotal    Int
  score              Int
  lastActivityAt     DateTime?
  lastSyncedAt       DateTime

  @@unique([accountId, snapshotDatePst])
  @@index([accountId])
}

model JlptKanji {
  id        String   @id @default(cuid())
  kanji     String   @unique
  nLevel    Int
  strokeCount Int?
  frequencyRank Int?
  schoolGrade Int?
  heisigKeyword String?
  unicodeHex String?
  sourceJlpt Int?
  primaryMeaning String?
  meanings   String[] @default([])
  onReadings String[] @default([])
  kunReadings String[] @default([])
  nanoriReadings String[] @default([])
  notes String[] @default([])
  wordExamples Json?
  enrichedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nLevel])
}

enum StudyReviewResult {
  correct
  wrong
  skipped
}

enum SubjectReviewSnapshotSource {
  sync
  ondemand
  submit
}

enum ReadingChallengeStatus {
  draft
  active
  completed
  archived
}

model ReadingChallenge {
  id            String                @id @default(cuid())
  slug          String                @unique
  name          String
  description   String
  status        ReadingChallengeStatus @default(draft)
  currencyCode  String                @default("JPY")
  startDatePst  String
  goalDatePst   String
  tripDatePst   String
  targetBaseYen Int
  scoringRules  Json
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  signoffs      ReadingSignoff[]
  signoffEntries ReadingSignoffEntry[]
  books         ReadingChallengeBook[]
  members       ReadingChallengeMember[]

  @@index([status])
  @@index([startDatePst, goalDatePst])
}

model StudyReviewAttempt {
  id           String            @id @default(cuid())
  accountId    String
  assignmentId Int
  subjectId    Int
  subjectType  String
  result       StudyReviewResult
  submittedAt  DateTime          @default(now())

  @@index([accountId, subjectId, submittedAt])
  @@index([accountId, submittedAt])
}

model SubjectReviewStatsSnapshot {
  id                    String                      @id @default(cuid())
  accountId             String
  subjectId             Int
  subjectType           String
  meaningCorrect        Int
  meaningIncorrect      Int
  meaningCurrentStreak  Int
  meaningMaxStreak      Int
  readingCorrect        Int
  readingIncorrect      Int
  readingCurrentStreak  Int
  readingMaxStreak      Int
  percentageCorrect     Int
  capturedAt            DateTime                    @default(now())
  source                SubjectReviewSnapshotSource @default(ondemand)

  @@index([accountId, subjectId, capturedAt])
  @@index([accountId, capturedAt])
}

model ReadingSignoff {
  id                 String   @id @default(cuid())
  challengeId        String?
  accountId          String
  signoffDatePst     String
  bookTitle          String
  pagesRead          Int
  minutesRead        Int
  didWanikaniReviews Boolean  @default(false)
  reviewsLeft        Int
  apprenticeCount    Int
  currentWkLevel     Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  challenge          ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@unique([accountId, signoffDatePst])
  @@index([challengeId, accountId])
  @@index([signoffDatePst])
  @@index([accountId])
}

model ReadingSignoffEntry {
  id                   String   @id @default(cuid())
  challengeId          String?
  accountId            String
  signoffDatePst       String
  bookTitle            String
  pagesRead            Int
  minutesRead          Int
  didWanikaniReviews   Boolean  @default(false)
  reviewWorkDone       Int      @default(0)
  reviewCorrect        Int      @default(0)
  reviewIncorrect      Int      @default(0)
  reviewSuccessPercent Int?
  createdAt            DateTime @default(now())

  challenge            ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@index([challengeId, accountId, signoffDatePst])
  @@index([accountId, signoffDatePst])
  @@index([accountId, createdAt])
  @@index([signoffDatePst])
}

model ReadingChallengeBook {
  id              String   @id @default(cuid())
  challengeId     String?
  accountId       String
  isbn            String
  title           String
  thumbnailUrl    String?
  manualCoverUrl  String?
  infoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  challenge    ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@unique([accountId, isbn, challengeId])
  @@index([challengeId, accountId])
  @@index([accountId])
}

model ReadingChallengeMember {
  id        String   @id @default(cuid())
  challengeId String?
  accountId String
  tracked   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  challenge ReadingChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@unique([challengeId, accountId])
  @@index([challengeId, accountId])
  @@index([accountId])
}
