{
  "name": "umakuma",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev -p ${WEB_PORT:-6400}",
    "build": "next build",
    "start": "next start -p ${WEB_PORT:-6400}",
    "test:smoke:local": "PLAYWRIGHT_BASE_URL=http://127.0.0.1:${WEB_PORT:-6400} playwright test -c playwright.smoke.local.config.ts",
    "test:smoke:build": "pnpm build && PLAYWRIGHT_BASE_URL=http://127.0.0.1:6401 playwright test -c playwright.smoke.build.config.ts",
    "test:smoke:install": "playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint",
    "loc:check": "node scripts/check-max-loc.mjs",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed:jlpt": "node scripts/seed-jlpt.mjs",
    "db:seed:jlpt:readings": "node scripts/build-jlpt-readings.mjs",
    "db:seed:kanji-levels": "node scripts/build-kanji-levels.mjs",
    "db:enrich:jlpt": "node scripts/enrich-jlpt-kanji.mjs",
    "test:news:candidates": "node scripts/news-candidate-analysis.mjs"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@prisma/client": "^6.19.3",
    "@types/kuromoji": "^0.1.3",
    "jsdom": "^29.0.2",
    "kuromoji": "^0.1.2",
    "next": "16.2.2",
    "next-auth": "^4.24.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "^2.4.1",
    "wanakana": "^5.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
